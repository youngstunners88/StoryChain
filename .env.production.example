# StoryChain Production Environment Configuration
# This is an example for production deployment

# ============================================
# REQUIRED: Authentication
# ============================================
ZO_CLIENT_IDENTITY_TOKEN=your_production_token_here

# ============================================
# OPTIONAL: LLM Provider API Keys
# ============================================
OPENROUTER_API_KEY=
INCEPTION_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=production

# ============================================
# Database Configuration
# ============================================
# Use persistent storage path in production
DATABASE_PATH=/var/lib/storychain/storychain.db

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=warn
LOG_DIR=/var/log/storychain

# ============================================
# Rate Limiting Configuration
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GENERAL=100
RATE_LIMIT_CREATE_STORY=10
RATE_LIMIT_AUTH=5

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# Feature Flags
# ============================================
ENABLE_STRIPE_PAYMENTS=false
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================
# Security Configuration
# ============================================
# Generate a strong random string: openssl rand -base64 32
SESSION_SECRET=your_very_secure_random_string_here
FORCE_HTTPS=true
