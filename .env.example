# StoryChain Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: Authentication
# ============================================
# Your Zo Client Identity Token - required for all API access
# Get yours at: https://kofi.zo.computer/?t=settings&s=advanced
ZO_CLIENT_IDENTITY_TOKEN=your_token_here

# ============================================
# OPTIONAL: LLM Provider API Keys
# ============================================
# OpenRouter API Key (for Reka Edge, Qwen 2.5)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Inception API Key (for Mercury 2)
# Get yours at: https://api.inceptionlabs.ai
INCEPTION_API_KEY=

# Groq API Key (for Llama 3.1, Gemma 2, Mixtral - FREE tier available)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# Google AI API Key (for Gemini Pro - FREE tier available)
# Get yours at: https://ai.google.dev/
GOOGLE_API_KEY=

# ============================================
# Server Configuration
# ============================================
# Port to run the server on (default: 3000)
PORT=3000

# Node environment (development, production)
NODE_ENV=development

# ============================================
# Database Configuration
# ============================================
# Path to SQLite database file (default: ./data/storychain.db)
DATABASE_PATH=./data/storychain.db

# ============================================
# Logging Configuration
# ============================================
# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Log directory (default: ./logs)
LOG_DIR=./logs

# ============================================
# Rate Limiting Configuration
# ============================================
# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# General API rate limit (default: 100)
RATE_LIMIT_GENERAL=100

# Story creation rate limit (default: 10)
RATE_LIMIT_CREATE_STORY=10

# Authentication rate limit (default: 5)
RATE_LIMIT_AUTH=5

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://kofi.zo.space,https://kofi.zo.computer

# ============================================
# Feature Flags
# ============================================
# Enable/disable Stripe payments (default: false)
ENABLE_STRIPE_PAYMENTS=false

# Stripe API Key (required if ENABLE_STRIPE_PAYMENTS=true)
STRIPE_API_KEY=

# Stripe Webhook Secret
STRIPE_WEBHOOK_SECRET=

# ============================================
# Security Configuration
# ============================================
# Session secret for signing cookies (generate a random string)
SESSION_SECRET=change_this_to_a_random_string_in_production

# Enable HTTPS redirect (default: false, set to true in production)
FORCE_HTTPS=false
