// Boober Database Schema
// PostgreSQL database for taxi hailing app

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  phone             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              Role      @default(PASSENGER)
  isEmailVerified   Boolean   @default(false)
  isPhoneVerified   Boolean   @default(false)
  isActive          Boolean   @default(true)
  profileImage      String?
  preferredLanguage String    @default("en")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastLoginAt       DateTime?

  // Relations
  passengerProfile  PassengerProfile?
  driverProfile     DriverProfile?
  ridesAsPassenger  Ride[]              @relation("PassengerRides")
  payments          Payment[]
  ratings           Rating[]
  safetyAlerts      SafetyAlert[]       @relation("UserSafetyAlerts")
  emergencyContacts EmergencyContact[]
  notifications     Notification[]
  devices           Device[]
  addresses         SavedAddress[]

  @@index([email])
  @@index([phone])
  @@map("users")
}

enum Role {
  PASSENGER
  DRIVER
  ADMIN
}

model PassengerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  totalRides      Int      @default(0)
  totalSpent      Decimal  @default(0)
  favouriteRoutes String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("passenger_profiles")
}

model DriverProfile {
  id                   String            @id @default(cuid())
  userId               String            @unique
  isAvailable          Boolean           @default(false)
  isOnline             Boolean           @default(false)
  isVerified           Boolean           @default(false)
  verificationStatus   VerificationStatus @default(PENDING)
  prdpNumber           String?
  prdpExpiry           DateTime?
  licenseNumber        String?
  licenseExpiry        DateTime?
  vehicleId            String?
  currentLocation      Json?
  totalRides           Int               @default(0)
  totalEarnings        Decimal           @default(0)
  rating               Decimal           @default(5.0)
  totalRatings         Int               @default(0)
  currentRoute         String?
  capacity             Int               @default(15)
  availableSeats       Int               @default(15)
  bankName             String?
  bankAccountNumber    String?
  bankAccountName      String?
  commissionRate       Decimal           @default(0.15)
  documents            DriverDocument[]
  ridesAsDriver        Ride[]            @relation("DriverRides")
  earnings             DriverEarning[]
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([isAvailable, isOnline])
  @@index([currentRoute])
  @@map("driver_profiles")
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model DriverDocument {
  id           String   @id @default(cuid())
  driverId     String
  type         DocumentType
  documentUrl  String
  isVerified   Boolean  @default(false)
  uploadedAt   DateTime @default(now())
  verifiedAt   DateTime?
  verifiedBy   String?
  rejectionReason String?

  driver DriverProfile @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("driver_documents")
}

enum DocumentType {
  PRDP
  DRIVERS_LICENSE
  VEHICLE_REGISTRATION
  VEHICLE_INSPECTION
  ID_DOCUMENT
  PROOF_OF_ADDRESS
  BANK_PROOF
}

model Vehicle {
  id              String        @id @default(cuid())
  registrationNum String        @unique
  make            String
  model           String
  year            Int
  colour          String
  capacity        Int           @default(15)
  vehicleType     VehicleType   @default(MINIBUS_TAXI)
  isActive        Boolean       @default(true)
  inspectionDate  DateTime?
  nextInspection  DateTime?
  insuranceExpiry DateTime?
  permitNumber    String?
  permitExpiry    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  driverProfiles DriverProfile[]

  @@map("vehicles")
}

enum VehicleType {
  MINIBUS_TAXI
  SEDAN
  SUV
  QUANTUM
}

// ============================================
// RIDE MANAGEMENT
// ============================================

model Ride {
  id              String      @id @default(cuid())
  passengerId     String
  driverId        String?
  vehicleId       String?
  status          RideStatus  @default(REQUESTED)
  pickupLocation  Json
  pickupAddress   String
  dropoffLocation Json
  dropoffAddress  String
  route           Json?
  distance        Float?      // in kilometers
  duration        Int?        // in minutes
  fare            Decimal
  fareBreakdown   Json?
  paymentMethod   PaymentMethod @default(CASH)
  paymentStatus   PaymentStatus @default(PENDING)
  rideType        RideType    @default(SHARED)
  passengerCount  Int         @default(1)
  notes           String?
  otp             String?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  passenger User    @relation("PassengerRides", fields: [passengerId], references: [id])
  driver    User?   @relation("DriverRides", fields: [driverId], references: [id])
  payment   Payment?
  rating    Rating?
  tracking  RideTracking[]

  @@index([status])
  @@index([passengerId])
  @@index([driverId])
  @@index([createdAt])
  @@map("rides")
}

enum RideStatus {
  REQUESTED
  SEARCHING
  DRIVER_ASSIGNED
  DRIVER_ARRIVING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_DRIVER_AVAILABLE
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  WALLET
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum RideType {
  SHARED
  PRIVATE
}

model RideTracking {
  id        String   @id @default(cuid())
  rideId    String
  location  Json
  timestamp DateTime @default(now())

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@map("ride_tracking")
}

// ============================================
// PAYMENT MANAGEMENT
// ============================================

model Payment {
  id              String        @id @default(cuid())
  rideId          String        @unique
  userId          String
  amount          Decimal
  currency        String        @default("ZAR")
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  transactionId   String?
  providerRef     String?
  provider        String?
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([transactionId])
  @@map("payments")
}

model DriverEarning {
  id          String   @id @default(cuid())
  driverId    String
  rideId      String
  fareAmount  Decimal
  commission  Decimal
  netAmount   Decimal
  tips        Decimal  @default(0)
  status      String   @default("PENDING")
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  driver DriverProfile @relation(fields: [driverId], references: [id])

  @@map("driver_earnings")
}

// ============================================
// RATINGS & REVIEWS
// ============================================

model Rating {
  id          String   @id @default(cuid())
  rideId      String   @unique
  fromUserId  String
  toUserId    String
  score       Int      // 1-5 stars
  comment     String?
  createdAt   DateTime @default(now())

  ride Ride @relation(fields: [rideId], references: [id], onDelete: Cascade)
  user User @relation(fields: [fromUserId], references: [id])

  @@index([toUserId])
  @@map("ratings")
}

// ============================================
// SAFETY FEATURES
// ============================================

model SafetyAlert {
  id          String      @id @default(cuid())
  userId      String
  rideId      String?
  type        AlertType
  status      AlertStatus @default(ACTIVE)
  location    Json?
  message     String?
  respondedAt DateTime?
  createdAt   DateTime    @default(now())

  user  User  @relation("UserSafetyAlerts", fields: [userId], references: [id])
  ride  Ride? @relation(fields: [rideId], references: [id])

  @@map("safety_alerts")
}

enum AlertType {
  EMERGENCY_SOS
  TRIP_SHARE
  DRIVER_ISSUE
  ROUTE_DEVIATION
  SPEED_ALERT
}

enum AlertStatus {
  ACTIVE
  RESOLVED
  FALSE_ALARM
}

model EmergencyContact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String
  relation  String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

// ============================================
// NOTIFICATIONS & DEVICES
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  RIDE_REQUEST
  RIDE_ACCEPTED
  DRIVER_ARRIVING
  RIDE_STARTED
  RIDE_COMPLETED
  PAYMENT_RECEIVED
  PROMOTION
  SAFETY_ALERT
  SYSTEM
}

model Device {
  id           String   @id @default(cuid())
  userId       String
  deviceToken  String?
  platform     String
  deviceId     String
  isActive     Boolean  @default(true)
  lastUsedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("devices")
}

// ============================================
// SAVED ADDRESSES
// ============================================

model SavedAddress {
  id          String   @id @default(cuid())
  userId      String
  label       String
  address     String
  location    Json
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("saved_addresses")
}

// ============================================
// ADMIN & SYSTEM
// ============================================

model Route {
  id              String   @id @default(cuid())
  name            String
  startPoint      Json
  endPoint        Json
  waypoints       Json?
  distance        Float
  estimatedTime   Int
  baseFare        Decimal
  perKmRate       Decimal
  isActive        Boolean  @default(true)
  popularStops    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("routes")
}

model FareConfig {
  id              String   @id @default(cuid())
  name            String
  baseFare        Decimal
  perKmRate       Decimal
  perMinuteRate   Decimal
  minFare         Decimal
  nightSurcharge  Decimal  @default(0)
  peakSurcharge   Decimal  @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("fare_configs")
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("system_configs")
}
