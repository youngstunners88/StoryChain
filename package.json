{
  "name": "storychain",
  "version": "2.0.0",
  "description": "StoryChain - Multi-LLM collaborative storytelling platform",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun run build.ts",
    "test": "bun test",
    "test:api": "bun test tests/api.test.ts",
    "test:security": "bun run tests/security/security-audit.ts",
    "test:stress": "bun test tests/stress/stress-test.ts",
    "db:init": "bun run src/database/init.ts",
    "db:backup": "bun run scripts/backup.ts",
    "db:migrate": "bun run migrations/run-v2.ts",
    "db:optimize": "sqlite3 data/storychain.db 'VACUUM; ANALYZE;'",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "validate": "bun run typecheck && bun run lint",
    "health": "curl -s http://localhost:3000/api/health | jq ."
  },
  "dependencies": {
    "hono": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "lucide-react": "^0.400.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/bun": "latest",
    "typescript": "^5.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
